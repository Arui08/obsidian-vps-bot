# Telegram Bot
TG_BOT_TOKEN=123456:ABC-DEF-your-bot-token
# 唯一允许使用 bot 的 Telegram 用户 ID（防陌生人乱用）
TG_CHAT_ID=123456789

# OpenAI 兼容接口（推荐用 Gemini 中转，文本质量好且便宜）
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://your-openai-compat-endpoint/v1
MODEL_FAST=gemini-2.5-flash
MODEL_SMART=gemini-2.5-pro

# Obsidian vault 在 VPS 上的路径
VAULT_PATH=/opt/obsidian-bot/vault

# 币安广场发帖（可选，没配就跳过自动发）
# 申请：https://www.binance.com 创作者中心
BINANCE_SQUARE_OPENAPI_KEY=
